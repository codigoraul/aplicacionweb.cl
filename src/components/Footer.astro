---
<footer class="bg-[#0a1628] border-t border-cyan-500/15 px-[6%] py-12 w-full">
  <div class="max-w-7xl mx-auto flex flex-wrap gap-8 justify-between items-start w-full">
    <div class="max-w-xs">
      <img src="/logo-app-blanco.svg" alt="Aplicación Web" class="h-24 mb-3" />
      <p class="text-slate-400 text-sm">Aplicaciones web simples, rápidas y económicas para negocios en Chile.</p>
    </div>
    <div>
      <h4 class="text-white font-semibold text-sm mb-3">Rubros</h4>
      {['Mecánica','Peluquería Canina','Gimnasios','Salones de Belleza','Ver todos'].map(l => (
        <a href="#rubros" class="block text-slate-400 text-sm mb-2 hover:text-cyan-400 transition-colors">{l}</a>
      ))}
    </div>
    <div>
      <h4 class="text-white font-semibold text-sm mb-3">Empresa</h4>
      {['Cómo funciona','Precios','Soporte','Contacto'].map(l => (
        <a href="#" class="block text-slate-400 text-sm mb-2 hover:text-cyan-400 transition-colors">{l}</a>
      ))}
    </div>
  </div>
</footer>
<div class="bg-[#020617] text-slate-600 text-xs text-center py-4 border-t border-white/5">
  <p>© 2026 Aplicación Web – Todos los derechos reservados.</p>
  <p class="mt-2">
    <a href="https://diseñopaginas.cl" target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:text-cyan-300 transition-colors">
      Diseño de páginas web profesionales
    </a>
  </p>
</div>
