<section id="contacto" class="relative overflow-hidden px-[6%] py-24 bg-gradient-to-br from-[#0a1628] via-[#0d2137] to-[#0a2a40] text-white text-center">
  <div class="absolute -top-40 -left-20 w-[500px] h-[500px] rounded-full bg-purple-700/15 blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-32 -right-16 w-[400px] h-[400px] rounded-full bg-cyan-500/15 blur-3xl pointer-events-none"></div>
  <div class="relative max-w-7xl mx-auto">
    <img src="/logo-app-blanco.svg" alt="Aplicación Web Chile – Apps para tu negocio" class="h-14 mx-auto mb-8" />
    <h2 class="text-3xl md:text-4xl font-extrabold">¿Listo para digitalizar tu negocio?</h2>
    <p class="mt-3 text-blue-300 text-lg max-w-xl mx-auto">
      Escríbenos hoy y te damos una demostración gratuita de la app para tu rubro.
    </p>
    <a
      href="https://wa.me/56900000000?text=Hola!%20Quiero%20una%20demo%20de%20mi%20app"
      target="_blank"
      class="inline-block mt-8 bg-gradient-to-r from-purple-600 to-cyan-500 text-white font-bold px-10 py-4 rounded-full shadow-[0_4px_20px_rgba(0,180,216,0.4)] hover:opacity-90 hover:-translate-y-0.5 transition-all text-lg"
    >
      Chatear por WhatsApp
    </a>
  </div>
</section>
