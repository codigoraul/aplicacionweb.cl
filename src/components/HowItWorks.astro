---
const steps = [
  {
    n: '01',
    title: 'Elige tu rubro',
    desc: 'Selecciona el tipo de negocio y cuéntanos tus necesidades básicas.',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    n: '02',
    title: 'Personalizamos tu app',
    desc: 'Adaptamos los colores, logo, módulos y textos a tu marca.',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  },
  {
    n: '03',
    title: 'Revisas y apruebas',
    desc: 'Te mostramos la demo para que pidas cambios antes del lanzamiento.',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
  {
    n: '04',
    title: 'Publicamos',
    desc: 'Tu app queda en línea con tu dominio y capacitamos a tu equipo.',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
];
---
<section id="como-funciona" class="px-[6%] py-20 bg-slate-50">
  <div class="text-center mb-12">
    <span class="inline-block bg-gradient-to-r from-purple-100 to-cyan-100 border border-cyan-300/40 text-cyan-700 text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-3">
      Proceso
    </span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900">¿Cómo funciona?</h2>
    <p class="text-slate-500 mt-2">En 4 simples pasos tu negocio estará digitalizado.</p>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
    {steps.map(s => (
      <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm flex flex-col gap-4 hover:border-cyan-300/50 hover:shadow-md transition-all">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-[#0a1628] text-cyan-400 flex items-center justify-center flex-shrink-0 border border-cyan-500/20" set:html={s.svg} />
          <span class="text-xs font-bold text-slate-400 tracking-widest">{s.n}</span>
        </div>
        <div>
          <h3 class="font-bold text-slate-900 mb-1">{s.title}</h3>
          <p class="text-sm text-slate-500">{s.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>
